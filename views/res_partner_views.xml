<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add LINE User ID to partner form -->
    <record id="res_partner_view_form_line" model="ir.ui.view">
        <field name="name">res.partner.form.line</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='website']" position="after">
                <field name="line_user_id" string="LINE ID"/>
            </xpath>
        </field>
    </record>
</odoo>
