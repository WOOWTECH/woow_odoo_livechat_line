<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add LINE tab to LiveChat channel form -->
    <record id="im_livechat_channel_view_form_line" model="ir.ui.view">
        <field name="name">im_livechat.channel.form.line</field>
        <field name="model">im_livechat.channel</field>
        <field name="inherit_id" ref="im_livechat.im_livechat_channel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='channel_rules']" position="after">
                <page string="LINE" name="line">
                    <group>
                        <group>
                            <field name="line_enabled"/>
                        </group>
                    </group>
                    <group invisible="not line_enabled">
                        <group string="LINE Messaging API Settings">
                            <field name="line_channel_id"/>
                            <field name="line_channel_secret" password="True"/>
                        </group>
                        <group string="Webhook Configuration">
                            <field name="line_webhook_url" widget="CopyClipboardChar"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
